{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oknatty-website",
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["node_modules", ".git", "package*.json", "tsconfig.json", "next.config.ts", "postcss.config.mjs", "eslint.config.mjs", "README.md", "CLAUDE.md", "AGENTS.md", "*.txt", "*.csv", "MOCKUP", "backup_html", "OKNATTY_etichette", "src", "public", "webp"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
